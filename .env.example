# Copy this file to .env.local for local dev, OR add the same keys in
# Vercel → Settings → Environment Variables for production.

# Supabase project URL (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Publishable (or anon) key (Project Settings → API → anon / publishable)
# Safe to expose to the browser; RLS enforces per-user access.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY_HERE
